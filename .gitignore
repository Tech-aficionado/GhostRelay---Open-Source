*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build artifacts
dist/
build/
out/
*.tsbuildinfo

# Cloudflare
.wrangler/
.mf/

# Vercel
.vercel/

# Next.js
.next/

# Testing
coverage/

# Misc
