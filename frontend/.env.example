# GhostRelay Frontend Environment Variables
# Copy this to .env.local and fill in your values

# The API URL for the Cloudflare Worker backend
# For local development: http://localhost:8787
# For production: https://email-alias-worker.your-subdomain.workers.dev
NEXT_PUBLIC_API_URL=http://localhost:8787

# Adsterra Ad Integration
# Get these from your Adsterra publisher dashboard (https://publishers.adsterra.com)
# Use a "Native Banner" ad unit — copy the key and invoke.js URL from the ad code
# Example ad code: <script src="https://pl29635025.effectivecpmnetwork.com/KEY/invoke.js"></script><div id="container-KEY"></div>
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=
NEXT_PUBLIC_ADSTERRA_BANNER_SCRIPT=

# Firebase Configuration
# Get these from your Firebase Console: Project Settings > General > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
