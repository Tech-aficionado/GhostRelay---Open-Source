# Worker environment variables are configured in wrangler.toml
# This file is for reference only.
#
# For production, use wrangler secrets:
#   npx wrangler secret put JWT_SECRET
#
# D1 database setup:
#   npx wrangler d1 create ghostrelay-db
#   (then update database_id in wrangler.toml)
#
# Apply schema:
#   npx wrangler d1 execute ghostrelay-db --local --file=../database/schema.sql
#
# Organization email forwarding (support@, sales@, etc.) is delivered to the
# inbox set in the ORG_FORWARD_TO variable. Set it in wrangler.toml [vars] or as
# a secret:  npx wrangler secret put ORG_FORWARD_TO
